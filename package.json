{
  "name": "design-system",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "storybook": "npm run storybook -w storybook"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^3.4.17"
  }
}
